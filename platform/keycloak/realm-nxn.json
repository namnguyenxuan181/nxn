{
  "realm": "nxn",
  "displayName": "NXN Data Platform",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "accessTokenLifespan": 3600,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "ai-platform",
      "name": "AI Platform / Portal",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:8300/*"
      ],
      "webOrigins": ["*"]
    },
    {
      "clientId": "superset",
      "name": "Superset",
      "enabled": true,
      "secret": "superset-secret",
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8088/*"],
      "webOrigins": ["http://localhost:8088"],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "airflow",
      "name": "Airflow",
      "enabled": true,
      "secret": "airflow-secret",
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8082/*"],
      "webOrigins": ["http://localhost:8082"],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {"name": "admin",         "description": "Platform administrator — full access"},
      {"name": "data_engineer", "description": "Read/write raw + staging + mart schemas"},
      {"name": "analyst",       "description": "Read-only on mart schema, use AI reports"},
      {"name": "ai_user",       "description": "Use chat and AI features"},
      {"name": "viewer",        "description": "Read-only basic access"}
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@nxn.local",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "admin", "temporary": false}],
      "realmRoles": ["admin", "data_engineer", "analyst", "ai_user", "viewer"]
    },
    {
      "username": "alice",
      "email": "alice@nxn.local",
      "firstName": "Alice",
      "lastName": "Analyst",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "alice", "temporary": false}],
      "realmRoles": ["analyst", "ai_user"]
    },
    {
      "username": "bob",
      "email": "bob@nxn.local",
      "firstName": "Bob",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "bob", "temporary": false}],
      "realmRoles": ["ai_user"]
    },
    {
      "username": "carol",
      "email": "carol@nxn.local",
      "firstName": "Carol",
      "lastName": "Engineer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "carol", "temporary": false}],
      "realmRoles": ["data_engineer", "analyst", "ai_user"]
    }
  ]
}
